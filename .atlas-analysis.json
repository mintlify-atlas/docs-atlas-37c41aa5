  "keyFeatures": [
    "Income and expense tracking with multi-currency support",
    "Category management with hierarchical organization",
    "Account management (wallets, savings, investments, credit cards)",
    "Budget planning and tracking with alerts",
    "Financial reports and export capabilities (Excel, PDF)",
    "JWT authentication with Google OAuth integration",
    "Soft delete pattern for data retention",
    "RESTful API with Swagger documentation"
  ],
  "publicApiSurface": [
    "POST /api/auth/register - Create new user account",
    "POST /api/auth/login - Authenticate user",
    "GET /api/auth/profile - Get current user profile",
    "POST /api/transactions - Create transaction",
    "GET /api/transactions - List transactions with filters",
    "GET /api/transactions/balance - Get current balance",
    "PATCH /api/transactions/:id - Update transaction",
    "DELETE /api/transactions/:id - Delete transaction (soft)",
    "POST /api/categories - Create category",
    "GET /api/categories - List categories",
    "POST /api/accounts - Create account",
    "GET /api/accounts - List accounts",
    "POST /api/budgets - Create budget",
    "GET /api/budgets - List budgets",
    "GET /api/budgets/:id/status - Get budget status",
    "GET /api/reports/summary - Get financial summary",
    "GET /api/reports/export/excel - Export transactions to Excel",
    "GET /api/reports/export/pdf - Export transactions to PDF"
  ]
